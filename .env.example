# =====================================================================
# Restobook — PLANTILLA de variables de entorno
# Copia este archivo a `.env` (local) y rellena los valores.
# En PRODUCCIÓN (Vercel) NO se usa este archivo: pega cada variable en
# Vercel → Settings → Environment Variables.
# Este archivo .example SÍ se versiona; el .env real NO (está en .gitignore).
# =====================================================================

# ---------- Base de datos (Prisma / PostgreSQL) ----------
# Supabase → Project Settings → Database → Connection string (modo "Pooler").
DATABASE_URL=

# ---------- NextAuth v5 (Auth.js) ----------
# Genera el secreto con:  openssl rand -base64 32
# AUTH_SECRET es el que usa v5; NEXTAUTH_SECRET se mantiene por compatibilidad (mismo valor).
AUTH_SECRET=
NEXTAUTH_SECRET=
# URL pública de la app. En Vercel: https://<tu-proyecto>.vercel.app
NEXTAUTH_URL=
NEXT_PUBLIC_APP_URL=

# ---------- Stripe ----------
# Dashboard de Stripe → Developers → API keys / Products / Webhooks.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ---------- Resend (emails transaccionales) ----------
# Resend → API Keys. EMAIL_FROM debe ser un remitente de un dominio VERIFICADO.
RESEND_API_KEY=
EMAIL_FROM=

# ---------- Supabase (almacenamiento de PDFs de facturas) ----------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Cron (recordatorios diarios) ----------
# Protege /api/cron/daily-reminders. Genera con:  openssl rand -hex 32
# En Vercel, Vercel Cron envía este valor automáticamente como Authorization: Bearer.
CRON_SECRET=
